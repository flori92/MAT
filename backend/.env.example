HOST=127.0.0.1
PORT=8787
OCR_PIPELINE_URL=http://127.0.0.1:8788
OCR_PIPELINE_TIMEOUT_MS=60000
TRANSLATION_CACHE_TTL_MS=86400000

# Optional Bearer token required by the extension.
BACKEND_AUTH_TOKEN=

# Provider keys live here, never in the extension.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional model overrides.
GEMINI_MODEL=gemini-2.5-flash
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TEXT_MODEL=gpt-4o-mini

# Public fallback translators if no model key is configured.
# Enabled by default so the extension works without user API keys.
# In production, replace this with a managed translation model when possible.
ENABLE_PUBLIC_TRANSLATION_FALLBACK=true
